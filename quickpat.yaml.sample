# QuickPat Configuration
#
# Copy this file to quickpat.yaml and edit as needed.
# Alternatively, place at ~/.config/quickpat/config.yaml for user-level config.
#
# API keys are read from environment variables — never put real keys in this file.
#   OPENAI_API_KEY, ANTHROPIC_API_KEY, DEEPINFRA_API_KEY

# ── LLM Provider ────────────────────────────────────────────────────
#
# Set "provider" to one of: none, openai, anthropic, ollama, vllm, deepinfra
# Then configure the matching section below.
# CLI flags --llm / --model / --llm-url override these values.
#
# Examples follow — uncomment the one that fits your setup.

# ── Example 1: No LLM (default — deterministic pipeline only) ──────
llm:
  provider: none

# ── Example 2: Anthropic (Claude via API) ──────────────────────────
# Set ANTHROPIC_API_KEY in your environment, then:
#
# llm:
#   provider: anthropic
#   anthropic:
#     model: claude-sonnet-4-20250514

# ── Example 3: Local Ollama ────────────────────────────────────────
# Start Ollama on your machine (`ollama serve`), pull a model, then:
#
# llm:
#   provider: ollama
#   ollama:
#     model: llama3.1
#     base_url: http://localhost:11434

# ── Example 4: Remote Ollama ──────────────────────────────────────
# Point to an Ollama instance on another host:
#
# llm:
#   provider: ollama
#   ollama:
#     model: llama3.1
#     base_url: http://gpu-server.example.com:11434

# ── Example 5: DeepInfra ──────────────────────────────────────────
# Set DEEPINFRA_API_KEY in your environment, then:
#
# llm:
#   provider: deepinfra
#   deepinfra:
#     model: Qwen/Qwen2.5-72B-Instruct

# ── Example 6: vLLM (self-hosted OpenAI-compatible server) ────────
# llm:
#   provider: vllm
#   vllm:
#     model: default
#     base_url: http://localhost:8000

# ── Example 7: OpenAI ─────────────────────────────────────────────
# Set OPENAI_API_KEY in your environment, then:
#
# llm:
#   provider: openai
#   openai:
#     model: gpt-4o-mini

# ── Pattern Generation ──────────────────────────────────────────────
pattern:
  # Root directory for generated patterns
  output_dir: ~/patterns

  # Chart strategy: "local" copies charts into the pattern repo,
  # "external" references them from a Helm repository URL
  chart_strategy: local

  # Validated Patterns clustergroup chart version
  clustergroup_version: "0.9.*"

# ── Infrastructure Chart Versions ───────────────────────────────────
infrastructure:
  vault_chart_version: "0.1.*"
  external_secrets_chart_version: "0.2.*"

# ── Registry URLs ───────────────────────────────────────────────────
registry:
  # AI Quickstart registry (fetches .gitmodules for quickpat list)
  quickstart_url: https://raw.githubusercontent.com/rh-ai-quickstart/ai-quickstart-pub/main/.gitmodules

  # Shared chart repo index (for freshness checks and fork detection)
  chart_repo_index_url: https://rh-ai-quickstart.github.io/ai-architecture-charts/index.yaml

  # GitHub org base URL for quickstart repos
  github_base: https://github.com/rh-ai-quickstart

  # HTTP timeout in seconds for registry fetches
  timeout: 10

# ── Platform Overrides ──────────────────────────────────────────────
# Override files generated under overrides/ for each platform
platforms:
  - AWS
  - Azure
  - GCP
  - IBMCloud
  - None
